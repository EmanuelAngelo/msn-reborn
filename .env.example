# Ambiente: local | production
APP_ENV=local
DEBUG=True
SECRET_KEY=dev-only-msn-reborn-secret-key-change-in-production

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=127.0.0.1,localhost,backend,frontend

# Frontend e Spotify (local)
FRONTEND_URL=http://127.0.0.1:5173
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/spotify/callback/

# CORS (separados por vírgula)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080

# Redis para WebSockets em produção/Docker (deixe vazio para InMemory local)
REDIS_URL=

# Spotify (opcional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# PostgreSQL (opcional — padrão é SQLite)
# DATABASE_URL=postgres://msn:msn@db:5432/msn
